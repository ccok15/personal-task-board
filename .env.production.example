APP_DOMAIN="example.com"

POSTGRES_DB="personal_task_board"
POSTGRES_USER="personal_task_board"
POSTGRES_PASSWORD="replace-this-with-a-strong-db-password"

DATABASE_URL="postgresql://personal_task_board:replace-this-with-a-strong-db-password@db:5432/personal_task_board?schema=public"
NEXTAUTH_URL="https://example.com"
NEXTAUTH_SECRET="replace-this-with-a-long-random-string"

ADMIN_USERNAME="admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-this-with-a-strong-admin-password"

SEED_SAMPLE_DATA="false"
